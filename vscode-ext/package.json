{
  "name": "safe-ai-factory",
  "displayName": "Safe AI Factory",
  "description": "Containerized coding agent workflow orchestrator.",
  "version": "0.0.1",
  "publisher": "JuroOravec",
  "license": "MIT",
  "icon": "resources/saifac-icon-green.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/JuroOravec/safe-ai-factory.git",
    "directory": "vscode-ext"
  },
  "bugs": {
    "url": "https://github.com/JuroOravec/safe-ai-factory/issues"
  },
  "homepage": "https://github.com/JuroOravec/safe-ai-factory#readme",
  "keywords": [
    "ai",
    "agents",
    "coding",
    "containerized",
    "safe-ai-factory",
    "spec-driven"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "tsup",
    "vscode:prepublish": "pnpm run build",
    "vsix": "vsce package --allow-package-all-secrets --allow-package-env-file --allow-missing-repository",
    "compile": "pnpm run check-types && pnpm run lint && tsup",
    "watch": "npm-run-all -p watch:*",
    "watch:tsup": "tsup --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && tsup --minify",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run build && pnpm run compile-tests",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip --exclude types",
    "test": "node ./out/test/runTest.js",
    "test:unit": "vitest run",
    "coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "consola": "^3.4.2",
    "@eslint/js": "^9",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25",
    "@types/vscode": "^1.85.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "glob": "^14",
    "knip": "^5.85.0",
    "mocha": "^10",
    "npm-run-all": "^4.1.5",
    "prettier": "^3",
    "tsup": "^8",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "vitest": "^2",
    "@vscode/vsce": "^3"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "saifac-explorer",
          "title": "Safe AI Factory",
          "icon": "resources/saifac-icon-mono.svg"
        }
      ]
    },
    "views": {
      "saifac-explorer": [
        {
          "id": "saifac-features",
          "name": "Features"
        },
        {
          "id": "saifac-runs",
          "name": "Runs"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "saifac-features",
        "contents": "The SAIFAC CLI is not installed or not in your PATH. You need it to run containerized swarms.\n\n[Install SAIFAC](https://github.com/JuroOravec/safe-ai-factory)\n[Refresh Status](command:saifac.recheckInstall)",
        "when": "!saifac.isCliInstalled"
      },
      {
        "view": "saifac-runs",
        "contents": "No CLI detected. Install SAIFAC to view and manage your agent runs.\n\n[Install SAIFAC](https://github.com/JuroOravec/safe-ai-factory)\n[Refresh Status](command:saifac.recheckInstall)",
        "when": "!saifac.isCliInstalled"
      },
      {
        "view": "saifac-runs",
        "contents": "No runs found.\n\nRight-click a feature in **Features** and select **Run** to start your swarm.",
        "when": "saifac.isCliInstalled"
      }
    ],
    "commands": [
      {
        "command": "saifac.recheckInstall",
        "title": "Recheck SAIFAC Installation"
      },
      {
        "command": "saifac.createFeature",
        "title": "Create Feature",
        "icon": "$(plus)"
      },
      {
        "command": "saifac.createDir",
        "title": "Create Folder",
        "icon": "$(new-folder)"
      },
      {
        "command": "saifac.createFile",
        "title": "Create File",
        "icon": "$(new-file)"
      },
      {
        "command": "saifac.refreshFeatures",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "saifac.runFeature",
        "title": "Run",
        "icon": "$(play)"
      },
      {
        "command": "saifac.debugFeature",
        "title": "Debug",
        "icon": "$(debug)"
      },
      {
        "command": "saifac.designFeature",
        "title": "Design",
        "icon": "$(edit)"
      },
      {
        "command": "saifac.refreshRuns",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "saifac.resumeRun",
        "title": "Resume",
        "icon": "$(play)"
      },
      {
        "command": "saifac.removeRun",
        "title": "Remove",
        "icon": "$(trash)"
      },
      {
        "command": "saifac.clearAllRuns",
        "title": "Clear All",
        "icon": "$(clear-all)"
      },
      {
        "command": "saifac.revealRunInFinder",
        "title": "Reveal in Explorer"
      },
      {
        "command": "saifac.copyRunId",
        "title": "Copy Run ID"
      },
      {
        "command": "saifac.copyRunName",
        "title": "Copy Name"
      },
      {
        "command": "saifac.showLogs",
        "title": "Show SAIFAC Logs",
        "icon": "$(output)"
      }
    ],
    "configuration": {
      "title": "Safe AI Factory",
      "properties": {
        "saifac.verbose": {
          "type": "boolean",
          "default": false,
          "description": "Enable verbose logging for the Safe AI Factory extension. When enabled, debug-level messages appear in the SAIFAC output panel."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "saifac.createFeature",
          "when": "view == saifac-features",
          "group": "navigation@1"
        },
        {
          "command": "saifac.createDir",
          "when": "view == saifac-features",
          "group": "navigation@2"
        },
        {
          "command": "saifac.createFile",
          "when": "view == saifac-features",
          "group": "navigation@3"
        },
        {
          "command": "saifac.refreshFeatures",
          "when": "view == saifac-features",
          "group": "navigation@4"
        },
        {
          "command": "saifac.showLogs",
          "when": "view == saifac-features",
          "group": "navigation@5"
        },
        {
          "command": "saifac.refreshRuns",
          "when": "view == saifac-runs",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "saifac.runFeature",
          "when": "viewItem == feature",
          "group": "inline@1"
        },
        {
          "command": "saifac.debugFeature",
          "when": "viewItem == feature",
          "group": "inline@2"
        },
        {
          "command": "saifac.designFeature",
          "when": "viewItem == feature",
          "group": "inline@3"
        },
        {
          "command": "saifac.resumeRun",
          "when": "viewItem == run_failed",
          "group": "inline@1"
        },
        {
          "command": "saifac.removeRun",
          "when": "viewItem =~ /^run_/",
          "group": "inline@2"
        },
        {
          "command": "saifac.clearAllRuns",
          "when": "viewItem == runProject",
          "group": "inline"
        },
        {
          "command": "saifac.revealRunInFinder",
          "when": "viewItem =~ /^run_/",
          "group": "1_modification@1"
        },
        {
          "command": "saifac.copyRunId",
          "when": "viewItem =~ /^run_/",
          "group": "1_modification@2"
        },
        {
          "command": "saifac.copyRunName",
          "when": "viewItem =~ /^run_/",
          "group": "1_modification@3"
        },
        {
          "command": "saifac.createFile",
          "when": "view == saifac-features && (viewItem == feature || viewItem == dir)",
          "group": "2_workspace@1"
        },
        {
          "command": "saifac.createDir",
          "when": "view == saifac-features && (viewItem == feature || viewItem == dir)",
          "group": "2_workspace@2"
        }
      ]
    }
  }
}